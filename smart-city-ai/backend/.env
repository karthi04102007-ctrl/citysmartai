# MongoDB Configuration
# Leave blank to run in In-Memory Database Fallback mode
MONGODB_URI=

# Database name
DATABASE_NAME=smart_city_ai

# SMTP / Email Notification Configuration
# Leave blank to run in Email Simulation mode (logged to stdout & returned in UI response)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@smartcity.gov

# Directories
UPLOAD_DIR=uploads
STATIC_DIR=static
